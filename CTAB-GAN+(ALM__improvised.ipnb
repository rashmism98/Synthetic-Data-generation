ut_type":"stream","name":"stdout","text":["Epoch 189 | Q=0.924 | P=0.978 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 190 | Q=0.925 | P=0.978 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 191 | Q=0.925 | P=0.978 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 192 | Q=0.923 | P=0.977 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 193 | Q=0.926 | P=0.977 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 194 | Q=0.923 | P=0.977 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 195 | Q=0.925 | P=0.977 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 196 | Q=0.923 | P=0.977 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 197 | Q=0.926 | P=0.977 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 198 | Q=0.925 | P=0.977 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 199 | Q=0.922 | P=0.978 | Pmin=0.50 | lambda=0.000 | mu=1.000\n"]},{"output_type":"stream","name":"stderr","text":[]},{"output_type":"stream","name":"stdout","text":["Epoch 200 | Q=0.924 | P=0.978 | Pmin=0.50 | lambda=0.000 | mu=1.000\n","Training finished.\n","\n","Saved synthetic to: /content/drive/MyDrive/CTAB-GAN-Plus-outputs/pirvision1_ctab-gan_alm.csv\n","Rows saved: 5000\n","Preview:\n","          PIR_1         PIR_2         PIR_3         PIR_4         PIR_5  \\\n","0  4.222300e+03  10683.396484  11070.221680  11131.799805  10994.051758   \n","1  4.222300e+03  11101.020508  11858.033203  12096.887695  11801.850586   \n","2  4.222300e+03  10742.833008  11059.143555  11034.367188  10872.710938   \n","3  1.544858e+06   9875.046875   9746.146484   9738.848633   9989.057617   \n","4  5.890646e+04  10676.928711  11259.817383  11500.323242  11335.828125   \n","\n","          PIR_6         PIR_7         PIR_8         PIR_9        PIR_10  ...  \\\n","0  10692.076172  10279.473633   9983.330078   9840.690430   9748.618164  ...   \n","1  11217.948242  10494.855469   9892.240234   9421.536133   9122.243164  ...   \n","2  10584.608398  10257.521484   9938.329102   9730.005859   9628.316406  ...   \n","3  10026.997070  10051.219727  10106.606445  10220.454102  10366.437500  ...   \n","4  10945.604492  10465.186523  10007.975586   9680.986328   9487.946289  ...   \n","\n","         PIR_50        PIR_51        PIR_52        PIR_53        PIR_54  \\\n","0  10982.364258  10816.810547  10702.635742  10541.884766  10396.659180   \n","1  11679.275391  11387.096680  11148.649414  10932.186523  10732.620117   \n","2  10823.956055  10754.505859  10717.989258  10616.140625  10568.437500   \n","3  10624.416016  10641.882812  10678.581055  10560.804688  10554.210938   \n","4  11214.177734  11118.326172  10952.570312  10722.010742  10546.610352   \n","\n","         PIR_55        Date      Time  Label  Temperature_F  \n","0  10256.340820  2024-09-08  __RARE__      1             86  \n","1  10506.926758  2024-09-08  __RARE__      0             88  \n","2  10488.216797  2024-09-08  __RARE__      1             86  \n","3  10501.572266  2024-09-08  __RARE__      1             86  \n","4  10428.725586  2024-08-08  __RARE__      0             87  \n","\n","[5 rows x 59 columns]\n"]}],"source":["# ==============================================================\n","# Generic Tabular WGAN-GP + ALM (Schema-aware) — READY TO RUN (Colab)\n","# Fixes: \"boolean value of NA is ambiguous\" in privacy filter\n","# ==============================================================\n","\n","!pip -q install pandas numpy scikit-learn tqdm torch\n","\n","import os, random\n","from dataclasses import dataclass, field\n","import numpy as np\n","import pandas as pd\n","from tqdm import tqdm\n","\n","import torch\n","import torch.nn as nn\n","from torch.utils.data import Dataset, DataLoader\n","\n","from sklearn.compose import ColumnTransformer\n","from sklearn.pipeline import Pipeline\n","from sklearn.preprocessing import OneHotEncoder, StandardScaler\n","from sklearn.impute import SimpleImputer\n","from sklearn.neighbors import NearestNeighbors\n","\n","# ------------------\n","# CONFIG (EDIT THESE)\n","# ------------------\n","DATA_PATH = \"/content/drive/MyDrive/CTAB-GAN-Plus-main/CTAB-GAN-Plus-main/data/pirvision_office_dataset2.csv\"  # <-- your CSV\n","OUT_PATH  = \"/content/drive/MyDrive/CTAB-GAN-Plus-outputs/pirvision1_ctab-gan_alm.csv\"\n","\n","TARGET_COL = None\n","EXCLUDE_TARGET_FROM_TRAINING = True\n","\n","SEED = 42\n","DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","print(\"Using device:\", DEVICE)\n","\n","# Training\n","BATCH_SIZE = 256\n","EPOCHS = 200\n","LATENT_DIM = 128\n","LR_G = 1e-4\n","LR_D = 2e-4\n","N_CRITIC = 5\n","LAMBDA_GP = 10.0\n","\n","# Stability\n","DROP = 0.15\n","NOISE0 = 0.05\n","NOISE_DECAY = 0.985\n","GRAD_CLIP = 1.0\n","\n","# ALM\n","ALM_WEIGHT_MAX = 2.0\n","WARMUP_EPOCHS = 30\n","LAMBDA_INIT = 0.5\n","MU_INIT = 1.0\n","LAMBDA_LR = 5e-2\n","MU_GROWTH = 2.0\n","\n","# Proxy weights (ALM guidance only)\n","WQ = dict(D=0.35, A=0.05, C=0.30, V=0.30)\n","WP = dict(DCR=0.25, Qdelta=0.25, I=0.50)\n","\n","# Schema inference\n","ID_UNIQUE_THRESH = 0.90\n","ID_NAME_KEYWORDS = (\"id\", \"uuid\", \"guid\")\n","DISCRETE_MAX_UNIQUE = 30\n","CLIP_QUANTILES = (0.001, 0.999)\n","\n","# Rare bucketing\n","RARE_MIN_COUNT = 20\n","RARE_TOKEN = \"__RARE__\"\n","\n","# Privacy boost generation\n","APPLY_PRIVACY_FILTER = True\n","DROP_EXACT_OVERLAPS = True\n","DROP_SYNTH_DUPLICATES = True\n","NN_FILTER_QUANTILE = 0.03\n","RESAMPLE_ROUNDS = 12\n","BATCH_MULT = 5\n","\n","# ------------------\n","# Repro\n","# ------------------\n","def set_seed(seed=42):\n","    random.seed(seed)\n","    np.random.seed(seed)\n","    torch.manual_seed(seed)\n","    torch.cuda.manual_seed_all(seed)\n","\n","set_seed(SEED)\n","\n","# ------------------\n","# Schema + preprocessing helpers\n","# ------------------\n","@dataclass\n","class Schema:\n","    drop_cols: list = field(default_factory=list)\n","    num_cols: list = field(default_factory=list)\n","    cat_cols: list = field(default_factory=list)\n","    int_cat_cols: set = field(default_factory=set)\n","    bounds: dict = field(default_factory=dict)\n","\n","def clean_basic(df: pd.DataFrame) -> pd.DataFrame:\n","    df = df.copy()\n","    for c in df.columns:\n","        if df[c].dtype == \"object\":\n","            df[c] = df[c].astype(str).str.strip()\n","            df[c] = df[c].replace({\"?\": np.nan, \"\": np.nan, \"nan\": np.nan, \"None\": np.nan})\n","    for c in df.columns:\n","        if df[c].dtype == \"object\":\n","            coerced = pd.to_numeric(df[c], errors=\"coerce\")\n","            if coerced.notna().mean() > 0.85:\n","                df[c] = coerced\n","    return df\n","\n","def infer_schema(df: pd.DataFrame,\n","                 target_col: str | None,\n","                 id_unique_thresh: float,\n","                 id_name_keywords,\n","                 discrete_max_unique: int,\n","                 clip_quantiles=(0.001, 0.999)) -> Schema:\n","    df = clean_basic(df)\n","    n = len(df)\n","    sch = Schema()\n","\n","    # ID-like columns\n","    for c in df.columns:\n","        if target_col and c == target_col:\n","            continue\n","        cname = str(c).lower()\n","        uniq_ratio = df[c].nunique(dropna=True) / max(1, n)\n","        if uniq_ratio >= id_unique_thresh or any(k in cname for k in id_name_keywords):\n","            sch.drop_cols.append(c)\n","\n","    df2 = df.drop(columns=sch.drop_cols, errors=\"ignore\")\n","\n","    for c in df2.columns:\n","        s = df2[c]\n","        if target_col and c == target_col:\n","            sch.cat_cols.append(c)\n","            continue\n","\n","        if s.dtype == \"object\" or str(s.dtype).startswith(\"category\") or pd.api.types.is_bool_dtype(s):\n","            sch.cat_cols.append(c)\n","            continue\n","\n","        if pd.api.types.is_numeric_dtype(s):\n","            s_non = s.dropna()\n","            nun = s_non.nunique()\n","            is_int_like = (len(s_non) == 0) or np.all(np.isclose(s_non.astype(float) % 1, 0))\n","            if is_int_like and nun <= discrete_max_unique:\n","                sch.cat_cols.append(c)\n","                sch.int_cat_cols.add(c)\n","            else:\n","                sch.num_cols.append(c)\n","                if len(s_non) > 0:\n","                    lo = float(s_non.quantile(clip_quantiles[0]))\n","                    hi = float(s_non.quantile(clip_quantiles[1]))\n","                    if np.isfinite(lo) and np.isfinite(hi) and lo < hi:\n","                        sch.bounds[c] = (lo, hi)\n","                    else:\n","                        sch.bounds[c] = (float(s_non.min()), float(s_non.max()))\n","                else:\n","                    sch.bounds[c] = (0.0, 0.0)\n","            continue\n","\n","        sch.cat_cols.append(c)\n","\n","    return sch\n","\n","def bucket_rare_categories(df: pd.DataFrame, cat_cols: list, min_count: int, rare_token: str) -> pd.DataFrame:\n","    df = df.copy()\n","    for c in cat_cols:\n","        vc = df[c].astype(str).value_counts(dropna=False)\n","        rare = set(vc[vc < min_count].index.astype(str))\n","        s = df[c].astype(str)\n","        s = s.where(~s.isin(rare), other=rare_token)\n","        # Restore missingness properly\n","        s = s.replace({\"nan\": np.nan, \"None\": np.nan, \"<NA>\": np.nan})\n","        df[c] = s\n","    return df\n","\n","def make_ohe():\n","    # Avoid min_frequency; we do rare bucketing ourselves\n","    try:\n","        return OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False)\n","    except TypeError:\n","        return OneHotEncoder(handle_unknown=\"ignore\", sparse=False)\n","\n","def build_preprocessor(schema: Schema) -> ColumnTransformer:\n","    num_pipe = Pipeline(steps=[\n","        (\"imputer\", SimpleImputer(strategy=\"median\")),\n","        (\"scaler\", StandardScaler()),\n","    ])\n","    cat_pipe = Pipeline(steps=[\n","        (\"imputer\", SimpleImputer(strategy=\"most_frequent\")),\n","        (\"ohe\", make_ohe()),\n","    ])\n","    return ColumnTransformer(\n","        transformers=[\n","            (\"num\", num_pipe, schema.num_cols),\n","            (\"cat\", cat_pipe, schema.cat_cols),\n","        ],\n","        remainder=\"drop\",\n","    )\n","\n","def decode_from_preprocessor(fake_np: np.ndarray, pre: ColumnTransformer, schema: Schema) -> pd.DataFrame:\n","    out = {}\n","    n_num = len(schema.num_cols)\n","\n","    if n_num > 0:\n","        scaler = pre.named_transformers_[\"num\"].named_steps[\"scaler\"]\n","        Xn = scaler.inverse_transform(fake_np[:, :n_num])\n","        for i, c in enumerate(schema.num_cols):\n","            out[c] = Xn[:, i]\n","\n","    if len(schema.cat_cols) > 0:\n","        ohe = pre.named_transformers_[\"cat\"].named_steps[\"ohe\"]\n","        Xc = fake_np[:, n_num:]\n","        sizes = [len(cats) for cats in ohe.categories_]\n","\n","        start = 0\n","        for j, c in enumerate(schema.cat_cols):\n","            k = sizes[j]\n","            block = Xc[:, start:start+k]\n","            if block.shape[1] == 0:\n","                raise ValueError(f\"OHE decode failed for '{c}': empty block.\")\n","            idx = block.argmax(axis=1)\n","            cats = ohe.categories_[j]\n","            out[c] = np.array(cats, dtype=object)[np.clip(idx, 0, len(cats)-1)]\n","            start += k\n","\n","    df = pd.DataFrame(out)\n","\n","    # Clip numerics\n","    for c in schema.num_cols:\n","        lo, hi = schema.bounds.get(c, (None, None))\n","        if lo is not None:\n","            df[c] = pd.to_numeric(df[c], errors=\"coerce\").clip(lo, hi)\n","\n","    # Int-like categorical columns: keep as FLOAT or python int, NOT pandas nullable Int64 (pd.NA causes sklearn issues)\n","    # We'll store as float with NaN, and you can cast after saving if desired.\n","    for c in schema.int_cat_cols:\n","        df[c] = pd.to_numeric(df[c], errors=\"coerce\").round()  # float; NaNs remain np.nan\n","\n","    return df\n","\n","# ------------------\n","# IMPORTANT FIX: sanitize frames before pre.transform / sklearn\n","# ------------------\n","def sanitize_for_sklearn(df: pd.DataFrame, schema: Schema) -> pd.DataFrame:\n","    \"\"\"Ensure no pd.NA reaches sklearn; convert pd.NA -> np.nan; stabilize dtypes.\"\"\"\n","    df = df.copy()\n","\n","    # Replace pandas NA scalars with numpy nan (prevents 'boolean value of NA is ambiguous')\n","    df = df.replace({pd.NA: np.nan})\n","\n","    # Force categorical columns to object/str (but preserve NaN)\n","    for c in schema.cat_cols:\n","        if c in df.columns:\n","            s = df[c]\n","            # keep NaN, turn others to string\n","            df[c] = s.where(s.isna(), s.astype(str))\n","\n","    # Force numeric columns to float\n","    for c in schema.num_cols:\n","        if c in df.columns:\n","            df[c] = pd.to_numeric(df[c], errors=\"coerce\")\n","\n","    return df\n","\n","# --------- Privacy-boost filtering ----------\n","def nn_threshold_from_real(pre: ColumnTransformer, real_df: pd.DataFrame, schema: Schema, q: float) -> float:\n","    keep = schema.num_cols + schema.cat_cols\n","    r = sanitize_for_sklearn(real_df[keep], schema)\n","    r_enc = pre.transform(r)\n","    nn_rr = NearestNeighbors(n_neighbors=2, metric=\"euclidean\").fit(r_enc)\n","    rr_dist, _ = nn_rr.kneighbors(r_enc)\n","    return float(np.quantile(rr_dist[:, 1], q))\n","\n","def filter_rows(pre: ColumnTransformer, real_df: pd.DataFrame, synth_df: pd.DataFrame, schema: Schema,\n","                thresh: float, drop_exact_overlaps=True, drop_duplicates=True) -> pd.DataFrame:\n","    keep = schema.num_cols + schema.cat_cols\n","    r = sanitize_for_sklearn(real_df[keep], schema)\n","    s = sanitize_for_sklearn(synth_df[keep], schema)\n","\n","    if drop_duplicates:\n","        s = s.drop_duplicates()\n","\n","    if drop_exact_overlaps:\n","        real_set = set(map(tuple, r.astype(str).values))\n","        s = s.loc[[tuple(row) not in real_set for row in s.astype(str).values]]\n","\n","    if len(s) == 0:\n","        return s\n","\n","    r_enc = pre.transform(r)\n","    s_enc = pre.transform(s)\n","\n","    nn = NearestNeighbors(n_neighbors=1, metric=\"euclidean\").fit(r_enc)\n","    d, _ = nn.kneighbors(s_enc)\n","    return s.loc[d[:, 0] >= thresh].copy()\n","\n","def generate_with_privacy_filter(G, pre, schema, real_df, decode_fn,\n","                                 N, latent_dim, device,\n","                                 q=0.03, max_rounds=12, batch_mult=5, seed=42):\n","    rng = np.random.default_rng(seed)\n","    thresh = nn_threshold_from_real(pre, real_df, schema, q=q)\n","    keep = schema.num_cols + schema.cat_cols\n","\n","    collected = []\n","    total = 0\n","\n","    for _ in range(max_rounds):\n","        need = N - total\n","        if need <= 0:\n","            break\n","\n","        bs = max(need * batch_mult, 512)\n","        z = torch.randn(bs, latent_dim, device=device)\n","        with torch.no_grad():\n","            fake = G(z).cpu().numpy()\n","\n","        syn = decode_fn(fake, pre, schema)\n","        syn = bucket_rare_categories(syn, schema.cat_cols, min_count=1, rare_token=RARE_TOKEN)\n","\n","        syn = filter_rows(\n","            pre, real_df, syn, schema,\n","            thresh=thresh,\n","            drop_exact_overlaps=DROP_EXACT_OVERLAPS,\n","            drop_duplicates=DROP_SYNTH_DUPLICATES\n","        )\n","\n","        if len(syn) > 0:\n","            take = min(need, len(syn))\n","            collected.append(syn.sample(take, random_state=int(rng.integers(1e9))))\n","            total += take\n","\n","    out = pd.concat(collected, axis=0).reset_index(drop=True) if collected else pd.DataFrame(columns=keep)\n","\n","    if total < N:\n","        print(f\"Warning: only {total}/{N} survived privacy filter at q={q}. \"\n","              f\"Try lower q (e.g. 0.02), higher max_rounds, or higher batch_mult.\")\n","\n","    return out\n","\n","# ------------------\n","# Load data + schema\n","# ------------------\n","if not os.path.exists(DATA_PATH):\n","    raise FileNotFoundError(f\"DATA_PATH not found: {DATA_PATH}\")\n","\n","df_raw = pd.read_csv(DATA_PATH, low_memory=False)\n","df_raw = clean_basic(df_raw)\n","\n","schema_full = infer_schema(\n","    df_raw,\n","    target_col=TARGET_COL,\n","    id_unique_thresh=ID_UNIQUE_THRESH,\n","    id_name_keywords=ID_NAME_KEYWORDS,\n","    discrete_max_unique=DISCRETE_MAX_UNIQUE,\n","    clip_quantiles=CLIP_QUANTILES\n",")\n","print(\"Dropped ID-like cols:\", schema_full.drop_cols)\n","\n","df = df_raw.drop(columns=schema_full.drop_cols, errors=\"ignore\")\n","\n","if TARGET_COL and TARGET_COL in df.columns and EXCLUDE_TARGET_FROM_TRAINING:\n","    df_train = df.drop(columns=[TARGET_COL])\n","    print(\"Excluded target from training:\", TARGET_COL)\n","else:\n","    df_train = df.copy()\n","\n","schema = infer_schema(\n","    df_train,\n","    target_col=None,\n","    id_unique_thresh=1.1,\n","    id_name_keywords=(),\n","    discrete_max_unique=DISCRETE_MAX_UNIQUE,\n","    clip_quantiles=CLIP_QUANTILES\n",")\n","print(f\"Schema: {len(schema.num_cols)} numeric | {len(schema.cat_cols)} categorical \"\n","      f\"(int-like cat: {len(schema.int_cat_cols)})\")\n","\n","df_train = bucket_rare_categories(df_train, schema.cat_cols, RARE_MIN_COUNT, RARE_TOKEN)\n","df_train = sanitize_for_sklearn(df_train, schema)\n","\n","pre = build_preprocessor(schema)\n","X_real = pre.fit_transform(df_train).astype(np.float32)\n","dim = X_real.shape[1]\n","print(\"Encoded dim:\", dim)\n","\n","# Dataset/dataloader\n","class TabularDataset(Dataset):\n","    def __init__(self, x):\n","        self.x = x.astype(np.float32)\n","    def __len__(self):\n","        return self.x.shape[0]\n","    def __getitem__(self, idx):\n","        return self.x[idx]\n","\n","dataset = TabularDataset(X_real)\n","dataloader = DataLoader(dataset, batch_size=BATCH_SIZE, shuffle=True, drop_last=True)\n","\n","# ------------------\n","# Models\n","# ------------------\n","class Generator(nn.Module):\n","    def __init__(self, latent_dim, data_dim, drop=0.15):\n","        super().__init__()\n","        self.net = nn.Sequential(\n","            nn.Linear(latent_dim, 256),\n","            nn.ReLU(True),\n","            nn.Dropout(drop),\n","            nn.Linear(256, 256),\n","            nn.ReLU(True),\n","            nn.Dropout(drop),\n","            nn.Linear(256, data_dim),\n","        )\n","    def forward(self, z):\n","        return self.net(z)\n","\n","class Discriminator(nn.Module):\n","    def __init__(self, data_dim, drop=0.15):\n","        super().__init__()\n","        self.net = nn.Sequential(\n","            nn.Linear(data_dim, 256),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            nn.Dropout(drop),\n","            nn.Linear(256, 256),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            nn.Dropout(drop),\n","            nn.Linear(256, 1),\n","        )\n","    def forward(self, x):\n","        return self.net(x).view(-1)\n","\n","G = Generator(LATENT_DIM, dim, drop=DROP).to(DEVICE)\n","D = Discriminator(dim, drop=DROP).to(DEVICE)\n","\n","opt_G = torch.optim.Adam(G.parameters(), lr=LR_G, betas=(0.5, 0.9))\n","opt_D = torch.optim.Adam(D.parameters(), lr=LR_D, betas=(0.5, 0.9))\n","\n","def add_instance_noise(x, std):\n","    if std <= 0:\n","        return x\n","    return x + std * torch.randn_like(x)\n","\n","def gradient_penalty(Dnet, real, fake):\n","    bs = real.size(0)\n","    alpha = torch.rand(bs, 1, device=real.device).expand_as(real)\n","    inter = alpha * real + (1 - alpha) * fake\n","    inter.requires_grad_(True)\n","    d_inter = Dnet(inter)\n","    grads = torch.autograd.grad(\n","        outputs=d_inter, inputs=inter,\n","        grad_outputs=torch.ones_like(d_inter),\n","        create_graph=True, retain_graph=True, only_inputs=True\n","    )[0]\n","    grads = grads.view(bs, -1)\n","    return ((grads.norm(2, dim=1) - 1) ** 2).mean()\n","\n","# ------------------\n","# Proxy metrics + ALM\n","# ------------------\n","class QualityPrivacyMetrics:\n","    def __init__(self, wq, wp):\n","        self.wq, self.wp = wq, wp\n","\n","    def _distribution_similarity(self, real, fake):\n","        gamma = 1.0\n","        rr = torch.cdist(real, real, p=2)\n","        ff = torch.cdist(fake, fake, p=2)\n","        rf = torch.cdist(real, fake, p=2)\n","        krr = torch.exp(-gamma * rr**2).mean()\n","        kff = torch.exp(-gamma * ff**2).mean()\n","        krf = torch.exp(-gamma * rf**2).mean()\n","        mmd2 = (krr + kff - 2*krf).clamp(min=0.0)\n","        return torch.exp(-mmd2).clamp(0.0, 1.0)\n","\n","    def _association_preservation(self, real, fake):\n","        def corr(x):\n","            x = (x - x.mean(0, keepdim=True)) / (x.std(0, keepdim=True) + 1e-6)\n","            return (x.T @ x) / (x.size(0) - 1)\n","        diff = torch.mean(torch.abs(corr(real) - corr(fake)))\n","        return torch.exp(-diff).clamp(0.0, 1.0)\n","\n","    def _diversity(self, fake):\n","        x = fake - fake.mean(0, keepdim=True)\n","        x = x / (x.norm(p=2, dim=1, keepdim=True) + 1e-6)\n","        sim = x @ x.T\n","        mask = ~torch.eye(sim.size(0), dtype=torch.bool, device=sim.device)\n","        return (1.0 - sim[mask].mean()).clamp(0.0, 1.0)\n","\n","    def _anomaly_preservation(self, real, fake):\n","        q1 = torch.quantile(real, 0.25, dim=0)\n","        q3 = torch.quantile(real, 0.75, dim=0)\n","        iqr = (q3 - q1).clamp(min=1e-6)\n","        hi = q3 + 1.5 * iqr\n","        lo = q1 - 1.5 * iqr\n","        rare_r = ((real > hi) | (real < lo)).float().mean()\n","        rare_f = ((fake > hi) | (fake < lo)).float().mean()\n","        return (1.0 - torch.abs(rare_r - rare_f)).clamp(0.0, 1.0)\n","\n","    def _dcr(self, real, fake):\n","        d = torch.cdist(fake, real, p=2)\n","        m, _ = d.min(dim=1)\n","        return torch.tanh(m.mean()).clamp(0.0, 1.0)\n","\n","    def _qdelta(self, real, fake):\n","        qs = torch.tensor([0.1, 0.25, 0.5, 0.75, 0.9], device=real.device)\n","        rq = torch.quantile(real, qs, dim=0)\n","        fq = torch.quantile(fake, qs, dim=0)\n","        diff = torch.abs(rq - fq).mean()\n","        return (diff / (diff + 1.0)).clamp(0.0, 1.0)\n","\n","    def _dup_risk(self, real, fake):\n","        x = torch.cat([real, fake], dim=0)\n","        d = torch.cdist(x, x, p=2)\n","        d = d - torch.eye(d.size(0), device=d.device) * 1e9\n","        return (d < 1e-3).float().mean().clamp(0.0, 1.0)\n","\n","    def __call__(self, real, fake):\n","        Dq = self._distribution_similarity(real, fake)\n","        Aq = self._anomaly_preservation(real, fake)\n","        Cq = self._association_preservation(real, fake)\n","        Vq = self._diversity(fake)\n","        Q = (self.wq[\"D\"]*Dq + self.wq[\"A\"]*Aq + self.wq[\"C\"]*Cq + self.wq[\"V\"]*Vq).clamp(0, 1)\n","\n","        DCR = self._dcr(real, fake)\n","        Qdelta = self._qdelta(real, fake)\n","        I = self._dup_risk(real, fake)\n","        P = (self.wp[\"DCR\"]*DCR + self.wp[\"Qdelta\"]*(1-Qdelta) + self.wp[\"I\"]*(1-I)).clamp(0, 1)\n","        return Q, P\n","\n","def pmin_schedule(epoch):\n","    if epoch < 50:  return 0.25\n","    if epoch < 120: return 0.40\n","    return 0.50\n","\n","class ALMController:\n","    def __init__(self, lambda_init, mu_init, lambda_lr, mu_growth, device):\n","        self.device = device\n","        self.lmbda = torch.tensor(lambda_init, device=device)\n","        self.mu = torch.tensor(mu_init, device=device)\n","        self.lambda_lr = lambda_lr\n","        self.mu_growth = mu_growth\n","        self.P_min = torch.tensor(0.25, device=device)\n","        self.residual_ema = None\n","\n","    def compute_loss(self, Q, P):\n","        residual = self.P_min - P\n","        violation = torch.relu(residual)\n","        L = (1.0 - Q) + self.lmbda * violation + 0.5 * self.mu * violation**2\n","        return L, residual.detach()\n","\n","    def update(self, residual_mean, ema_beta=0.9):\n","        r = torch.tensor(residual_mean, device=self.device)\n","        self.residual_ema = r if self.residual_ema is None else ema_beta*self.residual_ema + (1-ema_beta)*r\n","        self.lmbda = (self.lmbda + self.lambda_lr * self.residual_ema).clamp(min=0.0)\n","        if self.residual_ema.item() > 0:\n","            self.mu = self.mu * self.mu_growth\n","\n","def alm_weight_schedule(epoch):\n","    if epoch <= WARMUP_EPOCHS:\n","        return 0.0\n","    return min(ALM_WEIGHT_MAX, ALM_WEIGHT_MAX * (epoch - WARMUP_EPOCHS) / 50.0)\n","\n","qp_metrics = QualityPrivacyMetrics(WQ, WP)\n","alm = ALMController(LAMBDA_INIT, MU_INIT, LAMBDA_LR, MU_GROWTH, DEVICE)\n","\n","# ------------------\n","# TRAIN\n","# ------------------\n","G.train(); D.train()\n","for epoch in range(1, EPOCHS + 1):\n","    alm.P_min = torch.tensor(pmin_schedule(epoch), device=DEVICE)\n","    noise_std = NOISE0 * (NOISE_DECAY ** epoch)\n","\n","    d_losses, g_losses, qs, ps, residuals = [], [], [], [], []\n","    pbar = tqdm(dataloader, desc=f\"Epoch {epoch}/{EPOCHS}\", leave=False)\n","\n","    for real_batch in pbar:\n","        real_batch = real_batch.to(DEVICE)\n","\n","        # D\n","        for _ in range(N_CRITIC):\n","            z = torch.randn(real_batch.size(0), LATENT_DIM, device=DEVICE)\n","            fake_batch = G(z).detach()\n","\n","            d_real = D(add_instance_noise(real_batch, noise_std))\n","            d_fake = D(add_instance_noise(fake_batch, noise_std))\n","\n","            gp = gradient_penalty(D, add_instance_noise(real_batch, noise_std),\n","                                  add_instance_noise(fake_batch, noise_std))\n","\n","            d_loss = -(d_real.mean() - d_fake.mean()) + LAMBDA_GP * gp\n","\n","            opt_D.zero_grad()\n","            d_loss.backward()\n","            torch.nn.utils.clip_grad_norm_(D.parameters(), GRAD_CLIP)\n","            opt_D.step()\n","\n","        # G\n","        z = torch.randn(real_batch.size(0), LATENT_DIM, device=DEVICE)\n","        fake_batch = G(z)\n","\n","        adv_loss = -D(add_instance_noise(fake_batch, noise_std)).mean()\n","        Q, P = qp_metrics(real_batch, fake_batch)\n","        L_AL, residual = alm.compute_loss(Q, P)\n","\n","        w_alm = alm_weight_schedule(epoch)\n","        g_loss = adv_loss + w_alm * L_AL\n","\n","        opt_G.zero_grad()\n","        g_loss.backward()\n","        torch.nn.utils.clip_grad_norm_(G.parameters(), GRAD_CLIP)\n","        opt_G.step()\n","\n","        d_losses.append(d_loss.item())\n","        g_losses.append(g_loss.item())\n","        qs.append(Q.item()); ps.append(P.item()); residuals.append(residual.item())\n","\n","        pbar.set_postfix(Q=f\"{np.mean(qs):.3f}\", P=f\"{np.mean(ps):.3f}\", noise=f\"{noise_std:.3f}\")\n","\n","    alm.update(float(np.mean(residuals)))\n","    print(f\"Epoch {epoch:03d} | Q={np.mean(qs):.3f} | P={np.mean(ps):.3f} | \"\n","          f\"Pmin={alm.P_min.item():.2f} | lambda={alm.lmbda.item():.3f} | mu={alm.mu.item():.3f}\")\n","\n","print(\"Training finished.\")\n","\n","# ------------------\n","# GENERATE + DECODE + PRIVACY FILTER + SAVE\n","# ------------------\n","G.eval()\n","N_SYN = min(5000, len(X_real))\n","\n","if APPLY_PRIVACY_FILTER:\n","    syn_out = generate_with_privacy_filter(\n","        G=G, pre=pre, schema=schema, real_df=df_train, decode_fn=decode_from_preprocessor,\n","        N=N_SYN, latent_dim=LATENT_DIM, device=DEVICE,\n","        q=NN_FILTER_QUANTILE, max_rounds=RESAMPLE_ROUNDS, batch_mult=BATCH_MULT, seed=SEED\n","    )\n","else:\n","    with torch.no_grad():\n","        z = torch.randn(N_SYN, LATENT_DIM, device=DEVICE)\n","        fake = G(z).cpu().numpy()\n","    syn_out = decode_from_preprocessor(fake, pre, schema).drop_duplicates()\n","\n","# Final cleanup so saved CSV doesn't contain pd.NA\n","syn_out = syn_out.replace({pd.NA: np.nan})\n","\n","os.makedirs(os.path.dirname(OUT_PATH) or \".\", exist_ok=True)\n","syn_out.to_csv(OUT_PATH, index=False)\n","\n","print(\"\\nSaved synthetic to:\", OUT_PATH)\n","print(\"Rows saved:\", len(syn_out))\n","print(\"Preview:\")\n","print(syn_out.head())"]},{"cell_type":"code","execution_count":7,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":154714,"status":"ok","timestamp":1771651559091,"user":{"displayName":"Rashmi Singapura Manjunath","userId":"03442006476881626350"},"user_tz":480},"id":"5IXIEIrfpl_Y","outputId":"6c586ab3-6204-4161-efc5-b585d24c7ff3"},"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-2968061992.py:32: UserWarning: Could not infer format, so each element will be parsed individually, falling back to `dateutil`. To ensure parsing is consistent and as-expected, please specify a format.\n","  dt = pd.to_datetime(date_part + \" \" + time_part, errors=\"coerce\")\n"]},{"output_type":"stream","name":"stdout","text":["\n","===== QUALITY (Q) =====\n","         Q: 0.3154537091689477\n","     D_num: nan\n","     D_cat: 0.016000560542965416\n","     C_num: nan\n","     C_cat: 0.9005069971460237\n","         V: 0.029853569817854163\n","  num_cols: 1\n","  cat_cols: 71\n","\n","===== PRIVACY (P) =====\n","                 P: 0.925\n","          DCR_mean: 7.6157732009887695\n","         DCR_score: 1.0\n","           Q_delta: 67740.29736842103\n","      Qdelta_score: 0.75\n","  dup_within_synth: 0.0\n","   overlap_between: 0.0\n","           I_score: 1.0\n","      cat_ohe_used: 70\n","       cat_hi_card: 1\n"]},{"output_type":"execute_result","data":{"text/plain":["{'quality': {'Q': 0.3154537091689477,\n","  'D_num': nan,\n","  'D_cat': 0.016000560542965416,\n","  'C_num': nan,\n","  'C_cat': 0.9005069971460237,\n","  'V': 0.029853569817854163,\n","  'num_cols': 1,\n","  'cat_cols': 71},\n"," 'privacy': {'P': 0.925,\n","  'DCR_mean': 7.6157732009887695,\n","  'DCR_score': 1.0,\n","  'Q_delta': 67740.29736842103,\n","  'Qdelta_score': 0.75,\n","  'dup_within_synth': 0.0,\n","  'overlap_between': 0.0,\n","  'I_score': 1.0,\n","  'cat_ohe_used': 70,\n","  'cat_hi_card': 1}}"]},"metadata":{},"execution_count":7}],"source":["import pandas as pd\n","import numpy as np\n","from sklearn.compose import ColumnTransformer\n","from sklearn.preprocessing import OneHotEncoder\n","from sklearn.neighbors import NearestNeighbors\n","from scipy.stats import ks_2samp, entropy, spearmanr\n","from sklearn.metrics import normalized_mutual_info_score\n","\n","# =========================\n","# CONFIG (edit these)\n","# =========================\n","REAL_PATH_PATH = \"/content/drive/MyDrive/CTAB-GAN-Plus-main/CTAB-GAN-Plus-main/data/pirvision_office_dataset2.csv\"  # <-- your CSV\n","SYN_PATH  = \"/content/drive/MyDrive/CTAB-GAN-Plus-outputs/pirvision1_ctab-gan_alm.csv\"\n","# If your dataset has a label column you want excluded from distribution metrics:\n","TARGET_COL = \"Target\"   # set to None if you don't have one\n","\n","# High-cardinality categorical guard (prevents giant one-hot)\n","MAX_OHE_LEVELS = 100     # categoricals with > this unique values won't be one-hot encoded in privacy DCR calc\n","\n","# Privacy DCR speed cap (optional)\n","MAX_ROWS_FOR_DCR = 8000  # subsample for KNN distance if needed (set None for no cap)\n","\n","# =========================\n","# Helpers\n","# =========================\n","def combine_date_time(df: pd.DataFrame) -> pd.DataFrame:\n","    \"\"\"If Date/Time exist, create numeric DateTime seconds and drop Date/Time.\"\"\"\n","    out = df.copy()\n","    if (\"Date\" in out.columns) or (\"Time\" in out.columns):\n","        date_part = out[\"Date\"].astype(str) if \"Date\" in out.columns else \"1970-01-01\"\n","        time_part = out[\"Time\"].astype(str) if \"Time\" in out.columns else \"00:00:00\"\n","        dt = pd.to_datetime(date_part + \" \" + time_part, errors=\"coerce\")\n","        # seconds since epoch; NaT -> nan\n","        dt_int = dt.astype(\"datetime64[ns]\").astype(\"int64\").astype(\"float64\")\n","        dt_int[dt.isna().to_numpy()] = np.nan\n","        out[\"DateTime\"] = dt_int / 1e9\n","        for c in [\"Date\", \"Time\"]:\n","            if c in out.columns:\n","                out = out.drop(columns=[c])\n","    return out\n","\n","def infer_cat_num(df: pd.DataFrame, cols):\n","    \"\"\"Infer categorical vs numeric columns generically.\"\"\"\n","    cat_cols = []\n","    for c in cols:\n","        s = df[c]\n","        if s.dtype.name in [\"object\", \"category\", \"bool\"]:\n","            cat_cols.append(c)\n","        else:\n","            # treat low-cardinality numeric as categorical (often IDs/codes)\n","            nunique = s.nunique(dropna=True)\n","            n = len(s)\n","            if nunique <= 20 or (n > 0 and nunique / max(1, n) <= 0.02):\n","                # only if it's integer-like or small set\n","                cat_cols.append(c)\n","    num_cols = [c for c in cols if c not in cat_cols]\n","    return cat_cols, num_cols\n","\n","# ---------- Quality metrics ----------\n","def js_divergence(p, q, base=np.e):\n","    p = np.asarray(p, dtype=float); q = np.asarray(q, dtype=float)\n","    p = p / (p.sum() + 1e-12); q = q / (q.sum() + 1e-12)\n","    m = 0.5 * (p + q)\n","    return 0.5 * entropy(p, m, base=base) + 0.5 * entropy(q, m, base=base)\n","\n","def hist_jsd(xr, xs, bins=30, smooth=1e-9):\n","    xr = np.asarray(xr); xs = np.asarray(xs)\n","    lo = np.nanmin(np.concatenate([xr, xs])); hi = np.nanmax(np.concatenate([xr, xs]))\n","    if not np.isfinite(lo) or not np.isfinite(hi) or lo == hi:\n","        lo, hi = 0.0, 1.0 if lo == hi else (lo, hi)\n","    hr, _ = np.histogram(xr, bins=bins, range=(lo, hi))\n","    hs, _ = np.histogram(xs, bins=bins, range=(lo, hi))\n","    pr = (hr + smooth) / (hr.sum() + smooth*bins)\n","    ps = (hs + smooth) / (hs.sum() + smooth*bins)\n","    return float(js_divergence(pr, ps))\n","\n","def tvd_from_counts(p, q):\n","    keys = sorted(set(p).union(q), key=str)\n","    pv = np.array([p.get(k, 0.0) for k in keys], dtype=float)\n","    qv = np.array([q.get(k, 0.0) for k in keys], dtype=float)\n","    return 0.5 * np.abs(pv - qv).sum()\n","\n","def spearman_matrix(df, cols):\n","    m = len(cols)\n","    R = np.ones((m, m), dtype=float) * np.nan\n","    for i, a in enumerate(cols):\n","        R[i, i] = 1.0\n","        for j in range(i+1, m):\n","            b = cols[j]\n","            rho, _ = spearmanr(df[a], df[b], nan_policy=\"omit\")\n","            R[i, j] = R[j, i] = rho\n","    return R\n","\n","def nmi_matrix(df, cols):\n","    m = len(cols)\n","    M = np.ones((m, m), dtype=float) * np.nan\n","    for i, a in enumerate(cols):\n","        M[i, i] = 1.0\n","        for j in range(i+1, m):\n","            b = cols[j]\n","            M[i, j] = M[j, i] = normalized_mutual_info_score(df[a].astype(str), df[b].astype(str))\n","    return M\n","\n","def score_quality_Q(real_df: pd.DataFrame, syn_df: pd.DataFrame, target_col=None):\n","    cols = list(real_df.columns)\n","    if target_col and target_col in cols:\n","        cols = [c for c in cols if c != target_col]\n","\n","    cat_cols, num_cols = infer_cat_num(real_df, cols)\n","\n","    # --- D: numeric (KS, JSD, range coverage) ---\n","    D_parts = []\n","    for c in num_cols:\n","        xr = pd.to_numeric(real_df[c], errors=\"coerce\").dropna().values\n","        xs = pd.to_numeric(syn_df[c],  errors=\"coerce\").dropna().values\n","        if xr.size and xs.size:\n","            ks = ks_2samp(xr, xs).statistic\n","            jsd = hist_jsd(xr, xs)\n","            lo, hi = np.nanmin(xr), np.nanmax(xr)\n","            rc = float(np.mean((xs >= lo) & (xs <= hi))) if np.isfinite(lo) and np.isfinite(hi) else np.nan\n","            D_parts.append(np.nanmean([1-ks, 1-jsd, rc]))\n","    D_num = float(np.nanmean(D_parts)) if D_parts else np.nan\n","\n","    # --- D: categorical (1 - TVD) ---\n","    D_cat = np.nan\n","    if cat_cols:\n","        tvds = []\n","        rr = real_df[cat_cols].astype(str)\n","        ss = syn_df[cat_cols].astype(str)\n","        for c in cat_cols:\n","            pr = rr[c].value_counts(normalize=True).to_dict()\n","            ps = ss[c].value_counts(normalize=True).to_dict()\n","            tvds.append(1.0 - tvd_from_counts(pr, ps))\n","        D_cat = float(np.mean(tvds)) if tvds else np.nan\n","\n","    # --- C: numeric (Spearman matrix similarity) ---\n","    C_num = np.nan\n","    if len(num_cols) >= 2:\n","        Rr = spearman_matrix(real_df[num_cols].apply(pd.to_numeric, errors=\"coerce\"), num_cols)\n","        Rs = spearman_matrix(syn_df[num_cols].apply(pd.to_numeric, errors=\"coerce\"),  num_cols)\n","        mask = np.isfinite(Rr) & np.isfinite(Rs)\n","        C_num = float(1.0 - np.nanmean(np.abs(Rr[mask] - Rs[mask])))\n","\n","    # --- C: categorical (NMI matrix similarity) ---\n","    C_cat = np.nan\n","    if len(cat_cols) >= 2:\n","        rr = real_df[cat_cols].astype(str)\n","        ss = syn_df[cat_cols].astype(str)\n","        Mr = nmi_matrix(rr, cat_cols)\n","        Ms = nmi_matrix(ss, cat_cols)\n","        mask = np.isfinite(Mr) & np.isfinite(Ms)\n","        C_cat = float(1.0 - np.nanmean(np.abs(Mr[mask] - Ms[mask])))\n","\n","    # --- V: categorical coverage (real categories present in synthetic) ---\n","    V = np.nan\n","    if cat_cols:\n","        rr = real_df[cat_cols].astype(str)\n","        ss = syn_df[cat_cols].astype(str)\n","        cov = []\n","        for c in cat_cols:\n","            real_cats = set(rr[c].dropna().unique())\n","            syn_cats  = set(ss[c].dropna().unique())\n","            cov.append(len(real_cats & syn_cats) / max(1, len(real_cats)))\n","        V = float(np.mean(cov)) if cov else np.nan\n","\n","    parts = [x for x in [D_num, D_cat, C_num, C_cat, V] if not np.isnan(x)]\n","    Q = float(np.mean(parts)) if parts else 0.0\n","\n","    return {\n","        \"Q\": Q,\n","        \"D_num\": D_num,\n","        \"D_cat\": D_cat,\n","        \"C_num\": C_num,\n","        \"C_cat\": C_cat,\n","        \"V\": V,\n","        \"num_cols\": len(num_cols),\n","        \"cat_cols\": len(cat_cols),\n","    }\n","\n","# ---------- Privacy metrics ----------\n","def score_privacy_P(real_df: pd.DataFrame, syn_df: pd.DataFrame, target_col=None):\n","    cols = list(real_df.columns)\n","    if target_col and target_col in cols:\n","        cols = [c for c in cols if c != target_col]\n","\n","    # infer cat/num for privacy encoding\n","    cat_cols, num_cols = infer_cat_num(real_df, cols)\n","\n","    # High-cardinality categorical guard for one-hot\n","    cat_ok = []\n","    cat_hi = []\n","    for c in cat_cols:\n","        if real_df[c].nunique(dropna=True) <= MAX_OHE_LEVELS:\n","            cat_ok.append(c)\n","        else:\n","            cat_hi.append(c)\n","\n","    # Build numeric matrix for high-card categoricals via factorize (keeps KNN stable)\n","    def factorize_cols(df, cols_):\n","        out = pd.DataFrame(index=df.index)\n","        for c in cols_:\n","            codes, _ = pd.factorize(df[c].astype(\"string\").fillna(\"<NA>\"), sort=False)\n","            out[c] = codes.astype(\"float64\")\n","        return out\n","\n","    real_num = real_df[num_cols].apply(pd.to_numeric, errors=\"coerce\")\n","    syn_num  = syn_df[num_cols].apply(pd.to_numeric, errors=\"coerce\")\n","\n","    # median impute numeric using real medians\n","    med = real_num.median(numeric_only=True)\n","    real_num = real_num.fillna(med)\n","    syn_num  = syn_num.fillna(med)\n","\n","    real_hi = factorize_cols(real_df, cat_hi) if cat_hi else pd.DataFrame(index=real_df.index)\n","    syn_hi  = factorize_cols(syn_df,  cat_hi) if cat_hi else pd.DataFrame(index=syn_df.index)\n","\n","    # One-hot only safe categoricals\n","    def make_ohe():\n","        try:\n","            return OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False)\n","        except TypeError:\n","            return OneHotEncoder(handle_unknown=\"ignore\", sparse=False)\n","\n","    enc = ColumnTransformer([\n","        (\"num\", \"passthrough\", num_cols),\n","        (\"cat\", make_ohe(),    cat_ok),\n","    ])\n","\n","    Xr_base = enc.fit_transform(pd.concat([real_num, real_df[cat_ok].astype(str)], axis=1) if cat_ok else real_num)\n","    Xs_base = enc.transform(pd.concat([syn_num,  syn_df[cat_ok].astype(str)],  axis=1) if cat_ok else syn_num)\n","\n","    # append factorized high-card cols as numeric\n","    if cat_hi:\n","        X_real = np.hstack([Xr_base, real_hi.to_numpy(dtype=np.float64)])\n","        X_syn  = np.hstack([Xs_base, syn_hi.to_numpy(dtype=np.float64)])\n","    else:\n","        X_real = Xr_base\n","        X_syn  = Xs_base\n","\n","    X_real = np.asarray(X_real, dtype=np.float32)\n","    X_syn  = np.asarray(X_syn,  dtype=np.float32)\n","\n","    # Optional subsampling for speed\n","    if MAX_ROWS_FOR_DCR and len(X_real) > MAX_ROWS_FOR_DCR:\n","        idx = np.random.RandomState(42).choice(len(X_real), MAX_ROWS_FOR_DCR, replace=False)\n","        X_real_sub = X_real[idx]\n","    else:\n","        X_real_sub = X_real\n","\n","    if MAX_ROWS_FOR_DCR and len(X_syn) > MAX_ROWS_FOR_DCR:\n","        idx = np.random.RandomState(42).choice(len(X_syn), MAX_ROWS_FOR_DCR, replace=False)\n","        X_syn_sub = X_syn[idx]\n","    else:\n","        X_syn_sub = X_syn\n","\n","    # DCR (distance to closest real)\n","    nn = NearestNeighbors(n_neighbors=1).fit(X_real_sub)\n","    dists, _ = nn.kneighbors(X_syn_sub)\n","    dists = dists.ravel()\n","    DCR_mean = float(np.mean(dists))\n","\n","    # QΔ (quantile drift on numeric)\n","    quantiles = np.linspace(0.05, 0.95, 19)\n","    qd_vals = []\n","    for c in num_cols:\n","        xr = real_num[c].to_numpy()\n","        xs = syn_num[c].to_numpy()\n","        if xr.size and xs.size:\n","            qr = np.quantile(xr, quantiles)\n","            qs = np.quantile(xs, quantiles)\n","            qd_vals.append(float(np.mean(np.abs(qr - qs))))\n","    Q_delta = float(np.mean(qd_vals)) if qd_vals else float(\"nan\")\n","\n","    # I (dup within synth + overlap between)\n","    def norm_df(df):\n","        out = df[cols].copy()\n","        for c in cols:\n","            if np.issubdtype(out[c].dtype, np.number):\n","                out[c] = pd.to_numeric(out[c], errors=\"coerce\").round(6)\n","            else:\n","                out[c] = out[c].astype(str).str.strip()\n","        return out\n","\n","    real_norm = norm_df(real_df)\n","    syn_norm  = norm_df(syn_df)\n","\n","    dup_within_synth = float(1.0 - len(syn_norm.drop_duplicates()) / max(1, len(syn_norm)))\n","\n","    set_real = set(map(tuple, real_norm.to_numpy()))\n","    set_syn  = set(map(tuple, syn_norm.to_numpy()))\n","    overlap_between = float(len(set_real & set_syn) / max(1, len(syn_norm)))\n","\n","    # Map to [0,1] scores (same idea as your weights)\n","    def normalize01(x, lo=0.0, hi=1.0):\n","        if np.isnan(x): return np.nan\n","        if hi == lo: return 0.0\n","        v = (x - lo) / (hi - lo)\n","        return float(max(0.0, min(1.0, v)))\n","\n","    def inv01(x, cap=1.0):\n","        if np.isnan(x): return np.nan\n","        return float(max(0.0, min(1.0, 1.0 - x / cap)))\n","\n","    d95 = float(np.percentile(dists, 95)) if len(dists) else 1.0\n","    DCR_score = normalize01(DCR_mean, lo=0.0, hi=d95 if d95 > 0 else 1.0)\n","\n","    Qd_cap = float(np.nanmedian(qd_vals)) * 4 if qd_vals else (abs(Q_delta) + 1e-6)\n","    Qdelta_score = inv01(Q_delta, cap=Qd_cap if Qd_cap > 0 else 1.0)\n","\n","    I_combined = 0.5 * (dup_within_synth + overlap_between)\n","    I_score = inv01(I_combined, cap=0.10)\n","\n","    P = 0.5 * DCR_score + 0.3 * Qdelta_score + 0.2 * I_score\n","\n","    return {\n","        \"P\": float(P),\n","        \"DCR_mean\": DCR_mean,\n","        \"DCR_score\": DCR_score,\n","        \"Q_delta\": Q_delta,\n","        \"Qdelta_score\": Qdelta_score,\n","        \"dup_within_synth\": dup_within_synth,\n","        \"overlap_between\": overlap_between,\n","        \"I_score\": I_score,\n","        \"cat_ohe_used\": len(cat_ok),\n","        \"cat_hi_card\": len(cat_hi),\n","    }\n","\n","# =========================\n","# RUN EVALUATION\n","# =========================\n","real_df = pd.read_csv(REAL_PATH, low_memory=False)\n","syn_df  = pd.read_csv(SYN_PATH,  low_memory=False)\n","\n","# Align columns + handle Date/Time\n","all_cols = sorted(set(real_df.columns).union(set(syn_df.columns)))\n","real_df = combine_date_time(real_df.reindex(columns=all_cols))\n","syn_df  = combine_date_time(syn_df.reindex(columns=all_cols))\n","\n","q = score_quality_Q(real_df, syn_df, target_col=TARGET_COL)\n","p = score_privacy_P(real_df, syn_df, target_col=TARGET_COL)\n","\n","print(\"\\n===== QUALITY (Q) =====\")\n","for k in [\"Q\",\"D_num\",\"D_cat\",\"C_num\",\"C_cat\",\"V\",\"num_cols\",\"cat_cols\"]:\n","    print(f\"{k:>10}: {q.get(k)}\")\n","\n","print(\"\\n===== PRIVACY (P) =====\")\n","for k in [\"P\",\"DCR_mean\",\"DCR_score\",\"Q_delta\",\"Qdelta_score\",\"dup_within_synth\",\"overlap_between\",\"I_score\",\"cat_ohe_used\",\"cat_hi_card\"]:\n","    print(f\"{k:>18}: {p.get(k)}\")\n","\n","# Optional: return a single dict you can save as JSON\n","results = {\"quality\": q, \"privacy\": p}\n","results\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"8DJPUGIZA0lQ"},"outputs":[],"source":[]}],"metadata":{"accelerator":"GPU","colab":{"gpuType":"L4","machine_shape":"hm","provenance":[],"authorship_tag":"ABX9TyOmBo8/duiZJdT29iDYfl+N"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}